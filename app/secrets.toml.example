# .streamlit/secrets.toml.example
#
# Copy this to .streamlit/secrets.toml for local frontend development,
# OR set these as secrets in Streamlit Cloud dashboard.
#
# In Streamlit Cloud:
#   App settings → Secrets → paste the contents below with real values.
#
# NEVER commit secrets.toml to git — it is in .gitignore.

BACKEND_URL = "https://your-app-name.onrender.com"
